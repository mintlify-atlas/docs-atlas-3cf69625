  "keyFeatures": [
    "Multi-account rotation with intelligent quota-based selection",
    "Multiple authentication methods (AWS Builder ID, IAM Identity Center, Kiro CLI)",
    "Automatic Kiro CLI session synchronization",
    "Gradual context truncation for error 400 prevention",
    "Native Claude thinking mode support with configurable budgets",
    "High-performance SQLite-based account and usage management",
    "Automated token refresh and exponential backoff for rate limits",
    "Support for Claude Sonnet, Opus, Haiku, and extended context models"
  ],
